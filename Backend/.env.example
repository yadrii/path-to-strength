# MongoDB
MONGODB_URI=mongodb://localhost:27017/sahara
# For production with Supabase PostgreSQL, you'll use a different connection string

# JWT Secrets (use strong random strings in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# Firebase (download from Firebase Console)
# Keep serviceAccountKey.json in the src folder (add to .gitignore)
FIREBASE_PROJECT_ID=path-to-strength-9a945
FIREBASE_STORAGE_BUCKET=path-to-strength-9a945.firebasestorage.app

# Frontend URL (for email links, CORS, etc.)
FRONTEND_URL=http://localhost:5173

# Server
PORT=5000
NODE_ENV=development

# Email Service (optional - for password reset, email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@sahara.com
